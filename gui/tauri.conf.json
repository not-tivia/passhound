{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "PassHound",
  "version": "0.4.0",
  "identifier": "com.passhound.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PassHound",
        "width": 900,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
